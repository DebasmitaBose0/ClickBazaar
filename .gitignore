# 🏛️ ClickBazaar Master Protocol: GitIgnore
# Master security layer - prevents sensitive data exposure
# -------------------------------------------------------

# Node modules and package managers
node_modules/
package-lock.json
yarn.lock
pnpm-lock.yaml

# Environment & Configuration Files (CRITICAL - NEVER COMMIT)
.env
.env.local
.env.*.local
backend/.env
frontend/.env
frontend/.env.local

# IDE & Editor Settings
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Build Outputs
dist/
build/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Runtime Data
pids/
*.pid
*.seed
*.pid.lock

# Coverage reports
coverage/
.nyc_output/

# Optional dependencies
.pnpm-store/

# DB & Local Data
*.sqlite
db.sqlite
db.sqlite-journal
