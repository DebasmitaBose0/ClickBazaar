{
  "name": "clickbazaar",
  "private": true,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "concurrently \"npm --workspace frontend run dev\" \"npm --workspace backend run dev\"",
    "start": "npm --workspace backend start",
    "install": "npm install"
  },
  "devDependencies": {
    "concurrently": "^8.2.0"
  }
}
